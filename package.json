{
    "name": "fusion-dtl",
    "version": "0.1.0",
    "private": true,
    "type": "commonjs",
    "description": "Orquestacion de pruebas JavaScript con Bun para Fusion DTL, un protocolo de liquidacion distribuida en Rust.",
    "scripts": {
        "test": "bun run test:node",
        "test:node": "bun test tests/node",
        "test:rust": "cargo test --locked",
        "test:all": "bun run test:rust && bun run test:node",
        "build": "cargo build --all-targets --locked",
        "check": "cargo fmt --all -- --check && cargo clippy --all-targets --all-features --locked -- -D warnings",
        "ci": "bun run ci:local",
        "ci:local": "bun run check && bun run build && bun run fmt:check && bun run test:all",
        "ci:script": "bash scripts/ci.sh",
        "tests:script": "bash scripts/tests.sh",
        "fmt": "bunx prettier --write --config .prettierrc --ignore-path .prettierignore \"package.json\" \"tests/**/*.js\"",
        "fmt:check": "bunx prettier --check --config .prettierrc --ignore-path .prettierignore \"package.json\" \"tests/**/*.js\""
    },
    "keywords": [
        "dtl",
        "rust",
        "bun-test",
        "settlement",
        "ledger"
    ],
    "devDependencies": {
        "prettier": "^3.9.5"
    },
    "engines": {
        "bun": ">=1.3.0"
    }
}
